# .env

PORT=3000

# MongoDB
MONGO_URI=mongodb+srv://<tu_usuario>:<tu_contraseña>@<tu_cluster>.mongodb.net/<tu_nombre_db>?retryWrites=true&w=majority

# Sesiones de Express
SESSION_SECRET=UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA_MUY_SEGURA

# Google OAuth
GOOGLE_CLIENT_ID=TU_CLIENT_ID_DE_GOOGLE
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET_DE_GOOGLE
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
#JWT 
JWT_SECRET=UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA_MUY_SEGURA